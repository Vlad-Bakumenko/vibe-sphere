# Database
# App runtime connection. In production (Neon) use the POOLED connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/vibesphere?schema=public"
# Direct (non-pooled) connection for `prisma migrate`. In production (Neon) use
# the DIRECT connection string. Locally, set this to the same value as DATABASE_URL.
DIRECT_URL="postgresql://user:password@localhost:5432/vibesphere?schema=public"

# Auth.js
# AUTH_SECRET: generate with `npx auth secret` (or `openssl rand -base64 32`).
# On Vercel, AUTH_URL is not required (trustHost is enabled); Vercel sets the host.
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# UploadThing
UPLOADTHING_TOKEN=""

# Resend (email)
RESEND_API_KEY=""
# Optional sender; defaults to Resend's sandbox address until a domain is verified.
EMAIL_FROM="VibeSphere <onboarding@resend.dev>"
